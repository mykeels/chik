{
  "name": "chik",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "pre-commit": "lint-staged",
    "prepare": "husky install",
    "secrets": "bun ./scripts/user-secrets.script.ts",
    "api": "cd Chik.Exams && ASPNETCORE_ENVIRONMENT=Development dotnet watch --db false",
    "autogen": "bun ./scripts/autogen/index.script.ts ./openapi/ChikExams.openapi.json -p chikexams-client --output-dir .clients/chikexams-client",
    "migration:add": "dotnet ef migrations add $2 --project Chik.Exams --startup-project Chik.Exams.Api",
    "migration:update": "dotnet ef database update --project Chik.Exams --startup-project Chik.Exams.Api",
    "aspirate": "cd Chik.Exams.AppHost && aspirate generate && bun ./scripts/transform-aspirate-output.script.ts",
    "aspirate:deploy": "npm run aspirate && gh-pages -d Chik.AppHost/aspirate-output -b aspirate-output",
    "dotnet:build": "dotnet build -p WarningLevel=0",
    "dotnet:test": "dotnet test -p:WarningLevel=0 -p:SkipOpenApiGeneration=true",
    "dotnet:test:watch": "cd Chik.Exams.Tests && dotnet watch test /p:SkipOpenApiGeneration=true",
    "emails:css": "tailwindcss -i ./Chik.Exams/src/Mails/Templates/EmailTemplate.template.css -o ./Chik.Exams/Mails/Templates/EmailTemplate.css",
    "emails:render": "dotnet run --project Chik.Exams.Jobs -- emails:render",
    "emails:watch": "npx nodemon --watch Chik.Exams/src/Mails/Templates --ext cs --exec 'npm run emails:render'",
    "emails:preview": "cd Chik.Exams.Jobs/bin/Debug/net9.0/src/Mails/Templates/Samples && npx live-server --port=6008 --host=localhost",
    "emails": "npx concurrently \"npm run emails:watch\" \"npm run emails:preview\"",
    "post": "bun ./scripts/new-post.script.ts",
    "db:restore": "bun ./scripts/restore-db.script.ts data/dbs/Chik.Exams.sql",
    "repl": "cd Chik.Exams && ASPNETCORE_ENVIRONMENT=Development SkipOpenApiGeneration=true dotnet run --db false repl",
    "repl:db": "cd Chik.Exams && ASPNETCORE_ENVIRONMENT=Development SkipOpenApiGeneration=true dotnet run --db true repl"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "dotenv": "^17.2.3",
    "openai": "^6.15.0",
    "openapi-zod-client": "^1.18.3",
    "puppeteer": "^24.30.0",
    "react-d3-dag": "0.2.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@readme/openapi-parser": "^5.0.0",
    "@types/bun": "^1.2.19",
    "@types/node": "^22.5.5",
    "cac": "^6.7.14",
    "change-case": "^5.4.4",
    "cheerio": "^1.1.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "detect-package-manager": "^3.0.2",
    "eslint": "^9.9.0",
    "fast-glob": "^3.3.3",
    "gh-pages": "^6.3.0",
    "globals": "^15.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "openapi-types": "^12.1.3",
    "openapi3-ts": "^4.5.0",
    "playwright": "^1.53.1",
    "prettier": "^3.6.0",
    "prompts": "^2.4.2",
    "rimraf": "^6.0.1",
    "semver": "^7.7.2",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "wrangler": "^4.16.1"
  },
  "peerDependencies": {
    "chikexams-client": ".clients/chikexams-client"
  }
}
