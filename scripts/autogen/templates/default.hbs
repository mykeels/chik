type Api = ZodiosInstance<TEndpoints>;

export function createApiClient(baseUrl: string, consumerName: string, options?: ZodiosOptions): Api {

	if(typeof window === 'undefined') {
		options = options || {};
		options.axiosConfig = options.axiosConfig || {};
		options.axiosConfig.headers = options.axiosConfig.headers || {};
		options.axiosConfig.headers["X-Consumer-Name"] = consumerName;
		options.axiosConfig.headers["User-Agent"] = `+${consumerName}`;	
		
		if (options?.axiosInstance) {
			options.axiosInstance.defaults = options.axiosInstance.defaults || {
			headers: {} as HeadersDefaults & {
				[key: string]: AxiosHeaderValue;
			},
			};
			options.axiosInstance.defaults.headers.common["User-Agent"] = options.axiosConfig.headers["User-Agent"];
		}
	}

    return new Zodios(baseUrl, endpoints, options);
}